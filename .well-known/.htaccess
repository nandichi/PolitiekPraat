# MIME types voor agent-discovery bestanden
<IfModule mod_mime.c>
    AddType application/json .json
    AddType text/markdown .md
    AddType application/linkset+json .linkset
</IfModule>

<IfModule mod_headers.c>
    # Alle .well-known endpoints zijn publiek en mogen door AI-agents worden gelezen.
    Header set Access-Control-Allow-Origin "*"
    Header set Access-Control-Allow-Methods "GET, HEAD, OPTIONS"
    Header set X-Content-Type-Options "nosniff"
    Header set Cache-Control "public, max-age=3600"
</IfModule>

# Deze directory mag NIET door de markdown-negotiator worden omgezet.
# Bestanden hier zijn al in hun native formaat (JSON of Markdown).
