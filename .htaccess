# Basis instellingen
DirectoryIndex index.php
Options -Indexes

# PHP Upload limieten voor audio/video bestanden
php_value upload_max_filesize 100M
php_value post_max_size 100M
php_value max_execution_time 300
php_value max_input_time 300
php_value memory_limit 256M

# Rewrite engine aanzetten
RewriteEngine On
RewriteBase /

# Blokkeer publieke toegang tot testscripts (alleen echte testbestanden)
# Let op: niet te breed matchen, zodat legitieme bestanden zoals testimonials.php blijven werken.
RewriteRule ^test[-_].*\.php$ - [F,L,NC]
RewriteRule ^scripts/tests/.*$ - [F,L,NC]

# Allow direct access to files
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Allow direct access to directories
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Handle all routes
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php?url=$1 [QSA,L] 